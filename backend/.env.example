APP_ENV=local
APP_NAME="Voice Agent SaaS"
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./local.db
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me
PUBLIC_BASE_URL=http://localhost:8000
DEFAULT_TENANT_ID=demo
HUMAN_HANDOFF_FALLBACK_NUMBER=
OPENAI_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
LLM_RESPONSE_ENABLED=true
LLM_RESPONSE_TIMEOUT=8.0
TWILIO_AUTH_TOKEN=
STT_PROVIDER=mock
TTS_PROVIDER=mock
DEFAULT_LANGUAGE=bn-BD
# Admin API — shared secret (replace with JWT/OAuth2 before production)
ADMIN_SECRET_KEY=change-me-before-production
